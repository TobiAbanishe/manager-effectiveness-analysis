   "source": [
    "---\n",
    "## 5. Clustering Managers into Effectiveness Tiers\n",
    "\n",
    "Rather than ranking managers by a single number, clustering groups them into distinct profiles based on their full behavior pattern. This is more actionable for HR: managers in the same cluster tend to share the same strengths and gaps, so the same development intervention can be applied to the whole group.\n",
    "\n",
    "We use **K-Means clustering** on the 8 standardised behavior scores. The optimal number of clusters is selected using the **Elbow Method** and confirmed with the **Silhouette Score**.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare features: standardise behavior scores per manager\n",
    "X = mgr_scores[BEHAVIOR_COLS].values\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X)\n",
    "\n",
    "# Elbow method: inertia across k = 2 to 8\n",
    "inertias = []\n",
    "silhouettes = []\n",
    "k_range = range(2, 9)\n",
    "\n",
    "for k in k_range:\n",
    "    km = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    "    labels = km.fit_predict(X_scaled)\n",
    "    inertias.append(km.inertia_)\n",
    "    silhouettes.append(silhouette_score(X_scaled, labels))\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "axes[0].plot(list(k_range), inertias, 'o-', color='steelblue')\n",
    "axes[0].set_xlabel('Number of Clusters (k)')\n",
    "axes[0].set_ylabel('Inertia')\n",
    "axes[0].set_title('Elbow Method', fontweight='bold')\n",
    "axes[0].xaxis.set_major_locator(mticker.MultipleLocator(1))\n",
    "\n",
    "axes[1].plot(list(k_range), silhouettes, 's-', color='seagreen')\n",
    "axes[1].set_xlabel('Number of Clusters (k)')\n",
    "axes[1].set_ylabel('Silhouette Score')\n",
    "axes[1].set_title('Silhouette Score', fontweight='bold')\n",
    "axes[1].xaxis.set_major_locator(mticker.MultipleLocator(1))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/08_cluster_selection.png', bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "best_k = list(k_range)[silhouettes.index(max(silhouettes))]\n",
    "print(f'Best k by silhouette score: {best_k}  (score: {max(silhouettes):.3f})')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fit final model with k=3 (maps cleanly to Low / Mid / High tiers)\n",
    "# Override if silhouette strongly prefers another k\n",
    "FINAL_K = 3\n",
    "\n",
    "km_final = KMeans(n_clusters=FINAL_K, random_state=42, n_init=10)\n",
    "mgr_scores['cluster'] = km_final.fit_predict(X_scaled)\n",
    "\n",
    "# Label clusters by mean effectiveness score (highest = Tier 1)\n",
    "cluster_means = mgr_scores.groupby('cluster')['effectiveness_score'].mean().sort_values(ascending=False)\n",
    "tier_map = {c: f'Tier {i+1}' for i, c in enumerate(cluster_means.index)}\n",
    "tier_label_map = {\n",
