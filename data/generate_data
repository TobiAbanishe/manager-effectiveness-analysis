"""
generate_data.py
----------------
Generates synthetic data for the Manager Effectiveness Analysis project.
Produces two CSV files:
  - survey_responses.csv  : Individual employee survey ratings per manager
  - team_outcomes.csv     : Team-level attrition, engagement, and performance metrics

The data is designed to reflect the real-world findings of Google Project Oxygen,
where higher manager effectiveness scores correlate with better team outcomes.

Usage:
    python data/generate_data.py
"""

import numpy as np
import pandas as pd

RANDOM_SEED = 42
NUM_MANAGERS = 60
MIN_TEAM_SIZE = 6
MAX_TEAM_SIZE = 15

# The 8 core behaviors from Google Project Oxygen
OXYGEN_BEHAVIORS = [
    "good_coach",
    "empowers_team",
    "inclusive_environment",
    "results_oriented",
    "good_communicator",
    "supports_career_development",
    "clear_vision",
    "technical_competence",
]

DEPARTMENTS = ["Engineering", "Sales", "Operations", "Marketing", "Finance", "People"]

MANAGER_FIRST_NAMES = [
